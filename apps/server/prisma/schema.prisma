// VendorReceipt model was removed during the payment-direction
// refactor. The old direction (vendor paying admin and uploading
// proof) no longer exists; in the new model admin pays the vendor
// and uploads a receipt for transparency. That receipt lives on
// VendorPayout.receiptUrl. Stage 1 wiped all rows; this model
// removal is part of Stage 2.

model PartnerChangeRequest {
  id         String    @id @default(uuid())
  partnerId  String
  partner    Partner   @relation(fields: [partnerId], references: [id])
  fields     Json // Array of field names they want to edit e.g. ["companyName", "vatNumber", "CR"]
  reason     String
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED
