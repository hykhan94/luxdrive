// VendorReceiptStatus removed alongside the VendorReceipt model.
// VendorPayout has its own VendorPayoutStatus enum defined below.

enum PartnerInvoiceStatus {
  // Invoice issued, partner hasn't acted yet.
  PENDING

  // Past dueDate without proof upload. Auto-suspension cron may fire
  // for partners with any OVERDUE invoice past the grace period.
  OVERDUE

  // Partner has uploaded a payment-proof image. Admin needs to
  // confirm the proof matches their bank record before final PAID.
  PROOF_UPLOADED

  // Admin has confirmed receipt of the payment. Terminal state.
  PAID
}

enum InvoiceGenerationType {
  // DAILY is currently unused but kept in the enum to avoid a tricky
  // migration step. Prisma's migration generator tried to ALTER the
  // new `vendor_payouts.generationType` column TYPE before adding
  // the column (statement ordering bug), which aborted the whole
  // migration. Leaving DAILY in keeps the enum intact and skips the
  // AlterEnum step entirely. Drop it later in a dedicated migration
  // once Stage 3 is stable.
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum VendorPayoutStatus {
  // Payout owed but admin hasn't paid yet.
  PENDING

  // Admin marked PAID and uploaded the receipt image. Terminal state.
  PAID
}

// ============== BOOKING ASSIGNMENT OFFERS ==============
//
// Records each offer admin sends to a vendor for a booking. The
// existence of this table is what lets us enforce two key business
// rules without piling Json blobs onto Booking:
//
//   1. A vendor can be offered the same booking at most TWICE
//      (the initial offer + one re-offer after a "Price too low"
//      rejection). The unique (bookingId, vendorId, attemptNumber)
//      constraint prevents duplicates at a given attempt number; app
//      logic refuses to insert attemptNumber > 2.
//
//   2. A vendor who rejected for non-price reasons (car/driver not
//      available, unsuitable route) is excluded from any further
//      offers on this booking — the query that picks the next
//      eligible vendor excludes vendors who have any non-PRICE_TOO_LOW
//      rejection on this booking.
//
// The accepted offer's amount is denormalized to Booking.vendorPayoutAmount
// at acceptance for cheap reads from earnings/dashboard queries. This
// table remains the audit trail for "who got offered, who rejected,
// at what price, why".
model BookingAssignmentOffer {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Offered payout amount in SAR. Denormalized to Booking.vendorPayoutAmount
  // when this row's status flips to ACCEPTED.
  payoutAmount Decimal @db.Decimal(10, 2)

  // 1 = first time this vendor was offered the booking.
  // 2 = re-offer after the vendor rejected for "Price too low".
  // App logic refuses to insert a row with attemptNumber > 2 for the
  // same (bookingId, vendorId) pair.
  attemptNumber Int @default(1)

  status          OfferStatus
  rejectionReason OfferRejectionReason? // NULL unless status = REJECTED

  offeredAt   DateTime  @default(now())
  respondedAt DateTime? // Set when vendor accepts or rejects

  @@unique([bookingId, vendorId, attemptNumber])
  @@index([bookingId, status])
  @@index([vendorId])
  @@map("booking_assignment_offers")
}

enum OfferStatus {
  // Offer sent, vendor hasn't responded. A booking has at most ONE
  // PENDING offer at any time (the currently-active vendor).
  PENDING

  // Vendor accepted; their payoutAmount is now locked. Booking
  // transitions to CONFIRMED and the vendor proceeds to assign a
  // driver + vehicle.
  ACCEPTED

  // Vendor rejected with a reason. Booking either gets re-offered to
  // the same vendor at a higher price (PRICE_TOO_LOW) or moves to
  // the next eligible vendor (other reasons).
  REJECTED
}

enum OfferRejectionReason {
  // Vendor has no available car or driver for the trip date/time.
  // Vendor is excluded from any further offers on this booking.
  CAR_DRIVER_UNAVAILABLE

  // Vendor wants a higher payout. Admin can choose to re-offer the
  // same vendor at a better price (one re-offer maximum). If the
  // re-offer is also rejected, vendor is excluded.
  PRICE_TOO_LOW

  // Vendor doesn't service this route. Vendor is excluded from any
  // further offers on this booking.
  UNSUITABLE_ROUTE
}

