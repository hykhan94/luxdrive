// ============================================
// !!! DESTINATION PATH: apps/server/prisma/schema.prisma
// ============================================
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============== ENUMS ==============

enum Role {
  CUSTOMER
  PARTNER
  VENDOR
  ADMIN
  SALES
  OPERATIONS
  FINANCE
}

enum Position {
  HEAD
  SENIOR
  EXECUTIVE
}

enum Department {
  SALES
  OPERATIONS
  FINANCE
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum BookingStatus {
  // Booking created (e.g. partner submitted a ride request) but admin
  // hasn't yet offered it to a vendor.
  PENDING

  // Admin has entered a vendor payout amount and offered the booking
  // to a specific vendor. Vendor sees an Accept/Reject prompt.
  // Admin-only view shows "Assignment Offered"; partner sees the
  // masked "Awaiting Driver/Vehicle Assignment" state.
  ASSIGNMENT_OFFERED

  // Same vendor rejected with reason "Price too low" and admin chose
  // to re-offer at a higher price. A single vendor gets at most 2
  // offer attempts (first OFFERED, then RE_OFFERED). After two
  // rejections from the same vendor, the booking moves on to the
  // next eligible vendor with a fresh ASSIGNMENT_OFFERED.
  ASSIGNMENT_RE_OFFERED

  // Vendor accepted the offer. Now they need to assign a driver +
  // vehicle. Partner still sees "Awaiting Driver/Vehicle Assignment"
  // until the assignment is done.
  CONFIRMED

  IN_PROGRESS
  COMPLETED

  // Terminal: either explicitly cancelled OR all eligible vendors
  // (by category match) exhausted their offer attempts and rejected.
  // Partner-facing: just "Cancelled" with no internal detail leaked.
  CANCELLED
}

enum BookingSource {
  DIRECT
  PARTNER
}

enum TripType {
  ONE_WAY
  HOURLY
}

enum City {
  RIYADH
  JEDDAH
  MAKKAH
  MADINAH
}

enum VehicleClass {
  ECONOMY_SEDAN
  BUSINESS_SEDAN
  BUSINESS_SUV
  FIRST_CLASS
  ELECTRIC
  HIACE
  COASTER
  KING_LONG
}

enum VendorStatus {
  INVITED // Invitation sent, waiting for vendor to click the link
  ONBOARDING // Clicked link + set password; completing profile fields. Transitional state, ends on profile submit
  PENDING_REVIEW // Vendor submitted profile, waiting for admin review
  CHANGES_REQUESTED // Admin requested changes to profile
  APPROVED // Profile approved, vendor can operate
  SUSPENDED // Vendor suspended by admin
}

model VendorDocument {
  id                   String    @id @default(cuid())
  vendorId             String
  type                 String // CR, VAT, CHAMBER_OF_COMMERCE, BALADY, NATIONAL_ADDRESS, IBAN_LETTER
  fileUrl              String
  fileName             String?
  expiryDate           DateTime?
  // Tracks the last time the doc-expiry cron sent an expiry warning
  // or expired-notification for this document. Used to throttle
  // notifications to one per 7-day window, mirroring the pattern on
  // VehicleDocument/DriverDocument. Null on never-notified docs.
  lastExpiryNotifiedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, type])
  @@index([vendorId])
  @@index([type])
  @@map("vendor_documents")
}

// NEW ENUM: Driver review status
enum DriverStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  CHANGES_REQUESTED
}

// NEW ENUM: Vehicle review status
enum VehicleStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  UNDER_MAINTENANCE
  CHANGES_REQUESTED
}

// NEW ENUM: Bank update request status
enum BankUpdateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PartnerStatus {
  INVITED // Invitation sent, waiting for partner to click the link
  ONBOARDING // Clicked link + set password; completing profile fields. Transitional state, ends on profile submit
  PENDING_REVIEW // Partner submitted profile, waiting for admin review
  CHANGES_REQUESTED // Admin requested changes to profile OR partner has been granted an edit permission
  APPROVED // Profile approved, partner can use platform
  SUSPENDED // Partner suspended by admin
}

// Distinguishes the three flows that all use PartnerReviewComment:
//   ADMIN_REJECTION — admin flagged a field/doc during profile review; partner
//     must fix it before re-submission. UI shows amber "Admin requested changes",
//     locks other fields, gates Submit on all being addressed.
//   PARTNER_REQUEST — approved partner asked to edit a specific field; admin
//     approved the request. UI shows sky-blue "Editable at your request",
//     doesn't lock or gate anything.
//   ADMIN_COMMENT — admin added a neutral note about a field without rejecting
//     it. Informational only; doesn't lock or gate anything, but is still
//     visible so the partner sees the note.
enum PartnerReviewCommentType {
  ADMIN_REJECTION
  PARTNER_REQUEST
  ADMIN_COMMENT
}

// Discriminates the origin of a VendorReviewComment. Mirrors the partner
// side exactly — vendor was originally implemented with prefix-string
// discrimination, which turned out fragile. Semantics:
//   ADMIN_REJECTION — admin flagged the field/doc as needing changes
//   VENDOR_REQUEST  — created on approval of a vendor-initiated change
//                     request; marks the field as "vendor is editing this
//                     at their own request"
//   ADMIN_COMMENT   — used for admin accept audit trail (resolveOnCreate)
//                     and any other admin note that isn't a rejection
enum VendorReviewCommentType {
  ADMIN_REJECTION
  VENDOR_REQUEST
  ADMIN_COMMENT
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

enum LoginStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  UNKNOWN
}

// ============== BETTER AUTH MODELS ==============

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom LuxDrive fields
  phone         String?
  firstName     String?
  lastName      String?
  dob           DateTime?
  role          Role        @default(CUSTOMER)
  position      Position?
  department    Department?
  loyaltyTier   LoyaltyTier @default(BRONZE)
  loyaltyPoints Int         @default(0)
  isActive      Boolean     @default(true)

  // IP & Security
  registrationIp String?
  lastLoginIp    String?
  lastLoginAt    DateTime?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // LuxDrive relations
  bookings           Booking[]           @relation("CustomerBookings")
  partner            Partner?
  vendor             Vendor?
  loginLogs          LoginLog[]
  onlinePayments     OnlinePayment[]
  partnerTeamMembers PartnerTeamMember[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verification")
}

// ============== LUXDRIVE MODELS ==============

model LoginLog {
  id     String      @id @default(cuid())
  userId String?
  email  String
  status LoginStatus

  // IP & Location
  ip          String?
  city        String?
  region      String?
  country     String?
  countryCode String?
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  timezone    String?

  // Device Info
  deviceType     DeviceType @default(UNKNOWN)
  browser        String?
  browserVersion String?
  os             String?
  osVersion      String?
  userAgent      String?

  // Security
  failureReason String?
  isSuspicious  Boolean @default(false)

  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([ip])
  @@index([createdAt])
  @@map("login_logs")
}

model Partner {
  id             String        @id @default(cuid())
  userId         String        @unique
  companyName    String
  crNumber       String?
  vatNumber      String?
  creditLimit    Decimal       @default(0) @db.Decimal(10, 2)
  currentBalance Decimal       @default(0) @db.Decimal(10, 2)
  paymentTerms   Int           @default(30)
  status         PartnerStatus @default(PENDING_REVIEW)
  logoUrl        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  invitationToken     String?   @unique
  invitationSentAt    DateTime?
  invitationExpiresAt DateTime?
  invitedByUserId     String?

  // Profile submission tracking  
  profileSubmittedAt DateTime?
  profileReviewedAt  DateTime?
  profileReviewedBy  String?

  // Contact info (filled by partner)
  contactPerson String?
  contactPhone  String?
  contactEmail  String?
  address       String?

  // Document Details
  mouFileUrl              String?
  mouExpiryDate           DateTime?
  mouUploadedAt           DateTime?
  chamberOfCommerceNumber String?
  baladyNumber            String?
  nationalAddress         String?
  bankName                String?
  bankAccountNumber       String?
  bankIban                String?
  mouExpiryNotified       Boolean   @default(false) // Track if 2-month warning sent

  profileSnapshot Json? // Stores pre-edit snapshot for admin comparison

  // Admin review
  isProfileComplete Boolean @default(false)

  // ============== SUSPENSION / DEACTIVATION ==============
  // When admin flips `status` to SUSPENDED via the Suspend action, we
  // capture WHO did it, WHEN, WHY, and (critically) the status the partner
  // held before so Reactivate can restore it. Reason is required at the API
  // layer (admin can't suspend without one) and shown verbatim to the
  // partner on their locked dashboard.
  //
  // Note: this is separate from the existing `suspendedForDocs` boolean on
  // Vendor (auto-suspension for expired documents). Partner doesn't have
  // that mechanism today; this new set covers admin-initiated suspension
  // and future auto-suspension flows both.
  suspendedAt            DateTime?
  suspendedBy            String? // admin User.id
  suspensionReason       String? // shown to partner verbatim
  statusBeforeSuspension PartnerStatus? // restored on reactivate

  // Add relation for review comments
  reviewComments PartnerReviewComment[]
  documents      PartnerDocument[]      @relation("PartnerDocs")

  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings              Booking[]
  invoices              Invoice[]
  teamMembers           PartnerTeamMember[]
  partnerInvoices       PartnerInvoice[]
  partnerChangeRequests PartnerChangeRequest[]

  // Add indexes
  @@index([status])
  @@index([invitationToken])
  @@index([mouExpiryDate])
  @@map("partners")
}

// NEW MODEL: Partner review comments (field-level comments from admin)
model PartnerReviewComment {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  fieldName  String // Which field the comment is for: "crNumber", "vatNumber", "address", etc.
  comment    String // Admin's comment
  isResolved Boolean @default(false)

  // Discriminates admin-rejection vs partner-request. Default ADMIN_REJECTION
  // means existing rows retain the pre-refactor behaviour without any data
  // migration; all new writes explicitly set the value.
  type PartnerReviewCommentType @default(ADMIN_REJECTION)

  createdBy  String // Admin user ID
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([partnerId])
  @@index([isResolved])
  @@index([type])
  @@map("partner_review_comments")
}

model PartnerDocument {
  id                   String    @id @default(cuid())
  partnerId            String
  type                 String // CR, VAT, CHAMBER_OF_COMMERCE, BALADY, NATIONAL_ADDRESS, IBAN_LETTER
  fileUrl              String
  fileName             String?
  expiryDate           DateTime?
  // Mirrors VendorDocument.lastExpiryNotifiedAt — used by the
  // partner-profile-doc-expiry cron to throttle expiry warnings to
  // one per 7-day window per doc.
  lastExpiryNotifiedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  partner Partner @relation("PartnerDocs", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, type])
  @@index([partnerId])
  @@index([type])
  @@map("partner_documents")
}

// NEW MODEL: Partner invitation log (audit trail)
model PartnerInvitationLog {
  id           String   @id @default(cuid())
  partnerId    String?
  email        String
  companyName  String
  action       String // "SENT", "RESENT", "ACCEPTED", "EXPIRED"
  sentByUserId String
  sentByName   String
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([partnerId])
  @@map("partner_invitation_logs")
}

model PartnerTeamMember {
  id                   String    @id @default(cuid())
  partnerId            String
  userId               String? // linked once they accept invite
  name                 String
  email                String
  phone                String?
  role                 String    @default("member") // "admin", "manager", "booker", "viewer"
  status               String    @default("INVITED") // INVITED, ACTIVE, DEACTIVATED
  isActive             Boolean   @default(true)
  invitationToken      String?   @unique
  invitationSentAt     DateTime?
  invitationExpiresAt  DateTime?
  invitationAcceptedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("partner_team_members")
}

model Vendor {
  id                String       @id @default(cuid())
  userId            String       @unique
  companyName       String
  crNumber          String?
  vatNumber         String?
  bankName          String?
  bankAccountNumber String? // Account number
  bankIban          String?
  status            VendorStatus @default(PENDING_REVIEW)
  rating            Decimal?     @db.Decimal(2, 1)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // NEW: Invitation system (mirrors Partner)
  invitationToken     String?   @unique
  invitationSentAt    DateTime?
  invitationExpiresAt DateTime?
  invitedByUserId     String?

  // NEW: Profile review tracking
  profileSubmittedAt DateTime?
  profileReviewedAt  DateTime?
  profileReviewedBy  String?
  isProfileComplete  Boolean   @default(false)

  // NEW: Contact info (filled by vendor)
  contactPerson String?
  contactPhone  String?
  contactEmail  String?
  address       String?

  // NEW: MOU Document
  mouFileUrl        String?
  mouExpiryDate     DateTime?
  mouUploadedAt     DateTime?
  mouExpiryNotified Boolean   @default(false)

  // Document reference numbers (mirroring Partner). Distinct from the
  // documents relation — this is the number printed on / associated
  // with each doc, kept as separate fields so admin can validate them
  // against the actual uploaded PDFs.
  chamberOfCommerceNumber String?
  baladyNumber            String?
  nationalAddress         String?

  profileSnapshot Json? // Stores pre-edit snapshot for admin comparison
  logoUrl         String? // Company logo

  // Relations
  user                  User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles              Vehicle[]
  drivers               Driver[]
  bookings              Booking[]
  reviewComments        VendorReviewComment[] // NEW
  bankUpdateRequests    VendorBankUpdateRequest[] // NEW
  invitationLogs        VendorInvitationLog[] // NEW
  payouts               VendorPayout[]
  vendorDocuments       VendorDocument[]
  profileReviewRequests VendorProfileReviewRequest[] // NEW — vendor-initiated change requests
  assignmentOffers      BookingAssignmentOffer[] // Booking offers admin sent this vendor (audit trail)

  @@index([status])
  @@index([invitationToken])
  @@index([mouExpiryDate])
  @@map("vendors")
}

// Vendor payouts — admin OWES the vendor this amount for bookings
// performed in the period (new payment direction). Admin uploads a
// receipt image proving the bank transfer, purely for the vendor's
// transparency. Each payout aggregates a set of completed bookings.
model VendorPayout {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Receipt identifier shown to vendor (e.g. SAU-RCP-202606-001).
  // Generated when the payout is created so the vendor can reference
  // it in correspondence. Unique platform-wide.
  receiptNumber String @unique

  amount         Decimal               @db.Decimal(10, 2)
  periodStart    DateTime
  periodEnd      DateTime
  bookingCount   Int
  generationType InvoiceGenerationType // WEEKLY, MONTHLY

  status VendorPayoutStatus @default(PENDING)

  // Admin uploads the bank-transfer receipt when marking PAID.
  // Vendor can view but not modify — pure transparency artifact.
  receiptUrl        String?
  receiptFileName   String?
  receiptUploadedAt DateTime?
  paidAt            DateTime?
  paidBy            String? // admin userId
  adminNote         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([status])
  @@map("vendor_payouts")
}

model Vehicle {
  id               String        @id @default(cuid())
  vendorId         String
  category         VehicleClass
  make             String
  model            String
  year             Int
  plateNumber      String
  color            String?
  seats            Int           @default(4)
  features         String[]
  isActive         Boolean       @default(true)
  status           VehicleStatus @default(PENDING_REVIEW) // NEW
  suspendedForDocs Boolean       @default(false) // Auto-suspended due to expired documents
  mileage          Int? // NEW: Odometer reading
  editSnapshot     Json? // Snapshot of editable fields when CHANGES_REQUESTED, for diff display
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  vendor         Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  driver         Driver?                @relation("AssignedVehicle")
  documents      VehicleDocument[]
  reviewRequests VehicleReviewRequest[] // NEW
  reviewComments VehicleReviewComment[] // NEW field-level comments

  @@map("vehicles")
}

// Vendor review comments (field-level, mirrors PartnerReviewComment)
model VendorReviewComment {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  fieldName  String // "crNumber", "vatNumber", "companyName", "address", "mou", etc.
  comment    String
  isResolved Boolean @default(false)

  // Discriminates admin-rejection vs vendor-request vs plain admin comment.
  // Default ADMIN_REJECTION so existing rows retain pre-refactor semantics
  // without any data migration; all new writes explicitly set the value.
  // Mirrors PartnerReviewComment.type.
  type VendorReviewCommentType @default(ADMIN_REJECTION)

  createdBy  String // Admin user ID
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([vendorId])
  @@index([isResolved])
  @@index([type])
  @@map("vendor_review_comments")
}

// Vendor invitation audit log (mirrors PartnerInvitationLog)
model VendorInvitationLog {
  id           String   @id @default(cuid())
  vendorId     String?
  email        String
  companyName  String
  action       String // "SENT", "RESENT", "ACCEPTED", "EXPIRED"
  sentByUserId String
  sentByName   String
  createdAt    DateTime @default(now())

  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([vendorId])
  @@map("vendor_invitation_logs")
}

// Vendor bank update requests
model VendorBankUpdateRequest {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Requested new values
  requestedBankName          String?
  requestedBankAccountNumber String?
  requestedBankIban          String?

  // Current values at time of request (for audit)
  previousBankName          String?
  previousBankAccountNumber String?
  previousBankIban          String?

  status    BankUpdateRequestStatus @default(PENDING)
  reason    String? // Vendor's reason for change
  adminNote String? // Admin's note on approval/rejection

  // Who processed it
  processedBy String?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([status])
  @@map("vendor_bank_update_requests")
}

model VehicleDocument {
  id                   String    @id @default(cuid())
  vehicleId            String
  type                 String
  fileUrl              String
  fileName             String?
  expiryDate           DateTime?
  lastExpiryNotifiedAt DateTime? // Track when we last sent an expiry notification for this doc (prevents spam)
  createdAt            DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_documents")
}

// Driver review requests
// Can be either ADMIN_INITIATED (admin asks vendor to update) or VENDOR_INITIATED (approved vendor asks admin for permission to edit)
model DriverReviewRequest {
  id       String @id @default(cuid())
  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  // Which fields need attention. Keys here come from DRIVER_EDITABLE_FIELDS
  // (text fields like firstName/lastName/phone) and from the document type
  // codes (PROFILE_PHOTO, IQAMA_NATIONAL_ID, DRIVING_LICENSE).
  fields  String[]
  message String // Vendor's reason (VENDOR_INITIATED) OR admin's details (ADMIN_INITIATED)

  // Request type & status workflow
  requestType String  @default("ADMIN_INITIATED") // ADMIN_INITIATED | VENDOR_INITIATED
  status      String  @default("PENDING") // PENDING | APPROVED | REJECTED (only used for VENDOR_INITIATED)
  adminNote   String? // Admin's response when approving/rejecting a VENDOR_INITIATED request

  // Resolution tracking (used for ADMIN_INITIATED — when vendor has addressed all comments)
  isResolved Boolean   @default(false)
  createdBy  String // User ID (admin or vendor user)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([driverId])
  @@index([isResolved])
  @@index([status])
  @@index([requestType])
  @@map("driver_review_requests")
}

// Vehicle review requests
// Can be either ADMIN_INITIATED (admin asks vendor to update) or VENDOR_INITIATED (approved vendor asks admin for permission to edit)
model VehicleReviewRequest {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Which documents need re-upload
  documents String[] // ["vehiclePhotos", "numberPlates", "odometer", "insurance", "istimara"]
  message   String // Vendor's reason (VENDOR_INITIATED) OR admin's details (ADMIN_INITIATED)

  // Request type & status workflow
  requestType String  @default("ADMIN_INITIATED") // ADMIN_INITIATED | VENDOR_INITIATED
  status      String  @default("PENDING") // PENDING | APPROVED | REJECTED (only used for VENDOR_INITIATED)
  adminNote   String? // Admin's response when approving/rejecting a VENDOR_INITIATED request

  // Resolution tracking (used for ADMIN_INITIATED — when vendor has addressed all comments)
  isResolved Boolean   @default(false)
  createdBy  String // User ID (admin or vendor user)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([vehicleId])
  @@index([isResolved])
  @@index([status])
  @@index([requestType])
  @@map("vehicle_review_requests")
}

// Vendor profile change requests
// Mirrors DriverReviewRequest / VehicleReviewRequest. Approved vendors use this
// to request permission from the admin to edit specific profile fields or
// re-upload expired/expiring documents. Admin approves → those fields become
// editable / those docs can be re-uploaded.
model VendorProfileReviewRequest {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  // Which fields/docs need attention. Keys here come from VENDOR_EDITABLE_FIELDS
  // (text fields like companyName/contactPerson + bank fields + doc type codes
  // like CR/VAT/BALADY etc + 'logo' + 'mou').
  fields  String[]
  message String // Vendor's reason

  // Request type & status workflow
  requestType String  @default("VENDOR_INITIATED") // VENDOR_INITIATED only (admin-initiated changes go through reviewComments)
  status      String  @default("PENDING") // PENDING | APPROVED | REJECTED
  adminNote   String? // Admin's response when approving/rejecting

  // Resolution tracking — once the vendor has resubmitted the profile after the
  // change request was approved, isResolved → true and that "permission window"
  // closes for the listed fields.
  isResolved Boolean   @default(false)
