// Partner invoices — partner OWES admin this amount (new payment direction).
// Partner uploads a proof image; admin reviews and confirms PAID.
model PartnerInvoice {
  id            String  @id @default(cuid())
  invoiceNumber String  @unique // INV-2026-0089
  partnerId     String
  partner       Partner @relation(fields: [partnerId], references: [id])

  // Invoice details
  amount         Decimal               @db.Decimal(10, 2)
  bookingCount   Int                   @default(0)
  periodStart    DateTime
  periodEnd      DateTime
  generationType InvoiceGenerationType // WEEKLY, MONTHLY, CUSTOM

  // Due date (overdue after 3 days)
  dueDate DateTime

  // Viewing — used for sidebar badge counting on partner side so
  // unviewed invoices flash a notification dot.
  isViewedByPartner Boolean   @default(false)
  viewedByPartnerAt DateTime?

  // Single source of truth for payment progression. The previous
  // schema had redundant boolean flags (isPaymentReceived,
  // isConfirmed) plus timestamps that mirrored status transitions —
  // those have been collapsed into the enum + the two timestamps
  // below. Status flow: PENDING → (OVERDUE) → PROOF_UPLOADED → PAID.
  status PartnerInvoiceStatus @default(PENDING)

  // Partner-uploaded proof of payment (bank transfer screenshot etc).
  // Set when status transitions to PROOF_UPLOADED.
  paymentProofUrl        String?
  paymentProofFileName   String?
  paymentProofUploadedAt DateTime?

  // Admin confirmation. Set when status transitions to PAID.
  // confirmedBy is the admin userId who clicked Confirm.
  confirmedAt DateTime?
  confirmedBy String?

  // Reminders — cron tracks these to avoid spamming the partner.
  reminderSentAt DateTime?
  reminderCount  Int       @default(0)

  // Custom (mid-period) invoice support. Partner can request an
  // invoice for a specific date range to settle early. When the
  // month-end auto-invoice generates, it excludes bookings already
  // covered by a custom invoice (see isCustomInvoiced on Booking).
  dateRangeLabel  String? // e.g. "01 May 2026 – 15 May 2026"
  isCustom        Boolean @default(false)
  createdByUserId String? // userId of the partner who generated it

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]

  @@index([partnerId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("partner_invoices")
}

