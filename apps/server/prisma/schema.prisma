model Booking {
  id         String @id @default(cuid())
  bookingRef String @unique

  // Public-facing trip card token. Customers receive a short
  // WhatsApp message with a link to /trip/{shareToken}. The token
  // is opaque (non-guessable) so it can serve as a no-auth read
  // gate for the trip card page without exposing booking IDs in
  // URLs. Generated on creation in the controller layer via the
  // nanoid helper; permanent on the row, but the trip-card
  // endpoint refuses to render once the booking is >30 days past
  // its trip date.
  shareToken String? @unique

  // Relations
  customerId String?
  customer   User?    @relation("CustomerBookings", fields: [customerId], references: [id])
  partnerId  String?
  partner    Partner? @relation(fields: [partnerId], references: [id])
  vendorId   String?
  vendor     Vendor?  @relation(fields: [vendorId], references: [id])
  vehicleId  String?
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id])
  driverId   String?
  driver     Driver?  @relation(fields: [driverId], references: [id])

  // Source
  source     BookingSource @default(DIRECT)
  guestName  String?
  guestPhone String?
  guestEmail String?

  // Trip Details
  tripType TripType
  city     City
  route    String?
  hours    Int?

  pickupAddress  String
  pickupLat      Decimal? @db.Decimal(10, 8)
  pickupLng      Decimal? @db.Decimal(11, 8)
  dropoffAddress String
  dropoffLat     Decimal? @db.Decimal(10, 8)
  dropoffLng     Decimal? @db.Decimal(11, 8)

  tripDate     DateTime
  tripTime     String
  flightNumber String?

  // Airport fields (shown when route includes airport)
  terminalNo       String?
  terminalLocation String?

  // Route tariff reference (which admin-defined route was selected)
  routeTariffId String?

  // For hourly bookings — the duration label from the route (e.g., "6-8 Hours")
  hourlyDuration String?

  // Vehicle
  vehicleClass VehicleClass
  passengers   Int          @default(1)
  luggage      Int          @default(0)
  childSeat    Boolean      @default(false)

  // Pricing
  basePrice      Decimal @db.Decimal(10, 2)
  peakMultiplier Decimal @default(1.00) @db.Decimal(3, 2)
  vatAmount      Decimal @db.Decimal(10, 2)
  totalPrice     Decimal @db.Decimal(10, 2)

  // Status
  status        BookingStatus @default(PENDING)
  driverDetails Json?
  notes         String?

  // Vendor payout — the price admin offered the vendor for this
  // booking (in SAR). Set when admin enters the amount on the offer
  // screen. The accepted offer's amount is denormalized here for
  // cheap reads from settlement / earnings / dashboard queries.
  // Locked at acceptance time — admin cannot change after vendor
  // accepts (matches the "no in-system price edits" rule). NULL until
  // the first offer is sent.
  //
  // Admin's margin on this booking is computed at read time as
  // `totalPrice - vendorPayoutAmount`; not stored to keep a single
  // source of truth for both numbers.
  vendorPayoutAmount Decimal? @db.Decimal(10, 2)

  // Per-attempt offer history — see BookingAssignmentOffer model below.
  // This is the audit trail: which vendors got offered, which rejected
  // with what reason, attempt counts. Used to enforce the
  // "max 2 attempts per vendor" and "no re-offer to a vendor who
  // rejected for non-price reasons" rules.
  assignmentOffers BookingAssignmentOffer[]

  // Admin Notification Tracking
  isReadByAdmin   Boolean   @default(false)
  needsAttention  Boolean   @default(false)
  attentionReason String?
  attentionAt     DateTime?

  //Invoice
  partnerInvoiceId String?
  partnerInvoice   PartnerInvoice? @relation(fields: [partnerInvoiceId], references: [id])
  isCustomInvoiced Boolean         @default(false)
  customInvoicedAt DateTime?

  // Timestamps
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  confirmedAt    DateTime?
  completedAt    DateTime?
  onlinePayments OnlinePayment[]

  @@index([customerId])
  @@index([partnerId])
  @@index([vendorId])
  @@index([status])
  @@index([tripDate])
  @@index([bookingRef])
  @@index([isReadByAdmin])
  @@index([needsAttention])
  @@map("bookings")
}

