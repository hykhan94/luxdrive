# ============================================
# LuxDrive Backend — .env.example
# ============================================
# Copy this file to .env and fill in real values.
# .env is gitignored; this template is safe to commit.
# ============================================


# ----- Database -----
# Local Postgres: postgresql://user:password@localhost:5432/luxdrive
# Cloud SQL via Auth Proxy (local dev): postgresql://luxdrive_app:<encoded-pass>@127.0.0.1:5433/luxdrive?schema=public
# Cloud SQL via Private IP (production VM): postgresql://luxdrive_app:<encoded-pass>@10.x.x.x:5432/luxdrive?schema=public
# Special chars in password must be URL-encoded (@ -> %40, % -> %25, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/luxdrive?schema=public"


# ----- Server -----
PORT=5000


# ----- Better Auth -----
# Base URL where the auth endpoints are reachable from the FRONTEND's perspective.
# Local dev: http://localhost:5000
# Production: https://api.luxdriveksa.com
BETTER_AUTH_URL="http://localhost:5000"

# 32+ character random string used to sign sessions and cookies.
# Generate one with: openssl rand -base64 32
# NEVER reuse across environments. Rotate if leaked.
BETTER_AUTH_SECRET="replace-with-32-char-random-string-from-openssl"


# ----- CORS / Trusted Origins -----
# Comma-separated list of frontend origins allowed to call this backend.
# Used by BOTH the Express CORS middleware AND Better Auth's trustedOrigins.
# Each entry: exact scheme + host (+ port if non-default). No trailing slash.
# Local dev:   http://localhost:3000
# Production:  https://luxdriveksa.com,https://www.luxdriveksa.com
CORS_ORIGINS="http://localhost:3000"


# ----- Cookie Domain (production only) -----
# Set to the parent domain (with leading dot) when frontend and backend
# live on different subdomains of the same root. Enables cross-subdomain
# session cookies so login persists across luxdriveksa.com and api.luxdriveksa.com.
# Leave EMPTY in local dev — default cookie scoping works fine on localhost.
# Production: .luxdriveksa.com
COOKIE_DOMAIN=""


# ----- Google Maps / Places -----
# Server-side Maps key (Geocoding, Distance Matrix, Places).
# Different from the NEXT_PUBLIC_ key used by the frontend Maps JS.
# Restrict to API-only (no HTTP referrer restrictions on server keys).
GOOGLE_MAPS_API_KEY="AIzaSy_replace_with_real_server_side_key"


# ----- Google Cloud Storage -----
# GCS bucket name (no gs:// prefix)
GCS_BUCKET_NAME="luxdrive-storage"

# GCP project ID. Find it at the top of Cloud Console next to the project selector.
GCS_PROJECT_ID="your-gcp-project-id"

# Service account email. From the service-account JSON file's "client_email" field.
GCS_CLIENT_EMAIL="luxdrive-storage-admin@your-gcp-project-id.iam.gserviceaccount.com"

# Service account private key. From the service-account JSON file's "private_key" field.
# IMPORTANT: newlines must be escaped as literal \n (backslash + n) in .env files.
# The application code converts them back: process.env.GCS_PRIVATE_KEY.replace(/\\n/g, "\n")
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...REPLACE_WITH_REAL_KEY_CONTENT...\n-----END PRIVATE KEY-----\n"


# ----- Email (Resend) -----
# Resend API key from https://resend.com/api-keys
RESEND_API_KEY="re_replace_with_real_resend_api_key"

# Sender address. Must be on a domain you've verified in Resend.
# Format options:
#   "no-reply@luxdriveksa.com"
#   "LuxDrive <no-reply@luxdriveksa.com>"
EMAIL_FROM="LuxDrive <no-reply@luxdriveksa.com>"


# ----- Frontend -----
# URL where the frontend is reachable. Used for password-reset email links.
# Local dev:  http://localhost:3000
# Production: https://luxdriveksa.com
FRONTEND_URL="http://localhost:3000"
