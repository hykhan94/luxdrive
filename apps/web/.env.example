# ============================================
# LuxDrive Frontend (apps/web) — .env.example
# ============================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this template is safe to commit.
#
# Next.js env variable rules:
#   - Variables prefixed NEXT_PUBLIC_ are bundled into the browser-side JS.
#     Treat them as PUBLIC — anyone visiting the site can read them.
#   - Variables WITHOUT the prefix are SERVER-ONLY — only available in
#     API routes, server components, getServerSideProps, and server actions.
#     They are never sent to the browser.
# ============================================


# ----- Public (browser-side) -----

# URL of the LuxDrive backend API. The browser hits this directly.
# Local dev: http://localhost:3001
# Production: https://api.luxdriveksa.com
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Google Maps JavaScript API key — loaded in the browser for autocomplete,
# map display, etc. Public, but protected by HTTP referrer restrictions
# (set in Cloud Console: only luxdriveksa.com domains can use this key).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSy_replace_with_real_browser_side_maps_key"


# ----- Server-only (never exposed to browser) -----
# These power Next.js API routes / server components that need direct
# GCS access (e.g. server-side image proxy, signed upload URL generation).
# They MUST NOT be prefixed with NEXT_PUBLIC_ or they'll leak into the
# browser bundle and end up readable by every visitor.

# GCS bucket name (no gs:// prefix)
# GCS_BUCKET_NAME="luxdrive-storage"

# GCP project ID. Find it at the top of Cloud Console next to the project selector.
# GCS_PROJECT_ID="your-gcp-project-id"

# Service account email. From the service-account JSON file's "client_email" field.
# GCS_CLIENT_EMAIL="luxdrive-storage-admin@your-gcp-project-id.iam.gserviceaccount.com"

# Service account private key. From the service-account JSON file's "private_key" field.
# IMPORTANT: newlines must be escaped as literal \n (backslash + n) in .env files.
# The application code converts them back: process.env.GCS_PRIVATE_KEY.replace(/\\n/g, "\n")
# DOUBLE-CHECK this key is only used in server code (API routes, server components).
# If it ever appears in a client component or with a NEXT_PUBLIC_ prefix, ROTATE IT.
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...REPLACE_WITH_REAL_KEY_CONTENT...\n-----END PRIVATE KEY-----\n"
