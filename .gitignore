@"
# ============================================
# LuxDrive .gitignore
# ============================================

# ----- Dependencies -----
node_modules/
**/node_modules/
.pnp
.pnp.js

# ----- Build & output -----
.next/
**/.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo

# ----- Prisma generated client -----
# Regenerated by ``prisma generate``; never commit
**/generated/prisma/
apps/server/generated/

# ----- Environment variables (SECRETS) -----
# Block every env variant, anywhere in the tree
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
**/logs/

# ----- Editor & OS -----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- Test & coverage -----
coverage/
*.lcov
.nyc_output

# ----- Misc local -----
*.local
.cache/
.vercel/

# ----- Uploaded files (if any local) -----
uploads/
tmp/
"@ | Out-File -FilePath .gitignore -Encoding UTF8 -Force